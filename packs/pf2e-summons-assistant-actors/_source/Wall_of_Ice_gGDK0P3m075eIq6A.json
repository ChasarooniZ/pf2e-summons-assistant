    {
      "type": "action",
      "name": "Destroying A Section",
      "system": {
        "actionType": {
          "value": "passive"
        },
        "description": {
          "value": "<p>Each 10-foot-by-10-foot section of the wall has AC 10, Hardness 10, and 40 Hit Points, and it's immune to critical hits, cold damage, and precision damage. A section also has weakness 15 to fire;</p><ul><li><p><strong>Melting. </strong>A section of the wall destroyed by fire melts, evaporating into water and steam.</p></li><li><p><strong>Breaking.</strong> A section destroyed by means other than fire leaves behind a chilling mass of ice that is difficult terrain and deals @Damage[floor( (@actor.level - 1) / 2 )d6[cold]] damage to any creature passing through it.</p></li></ul>",
          "gm": ""
        },
